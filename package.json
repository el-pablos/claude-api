{
  "name": "claude-api",
  "version": "1.0.0",
  "description": "Claude API Key Pooling Proxy — multi API key rotation, auto failover, monitoring dashboard. Copilot-API style.",
  "keywords": [
    "claude",
    "anthropic",
    "api",
    "proxy",
    "pooling",
    "load-balancer",
    "api-key-rotation"
  ],
  "homepage": "https://github.com/el-pablos/claude-api#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/el-pablos/claude-api.git"
  },
  "license": "MIT",
  "author": "el-pablos <yeteprem.end23juni@gmail.com>",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "start": "node --import tsx/esm src/index.ts",
    "dev": "node --import tsx/esm --watch src/index.ts",
    "build": "tsc",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.1",
    "hono": "^4.7.10",
    "zod": "^3.24.4",
    "undici": "^7.10.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.1",
    "@vitest/coverage-v8": "^3.2.1"
  }
}
