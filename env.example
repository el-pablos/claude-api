# Server
PORT=4141
HOST=0.0.0.0
NODE_ENV=development

# Security
API_SECRET_KEY=your-secret-key-for-dashboard
ENCRYPTION_KEY=your-32-char-encryption-key-here

# Pool
POOL_STRATEGY=round-robin
POOL_STATE_FILE=./data/pool.json
POOL_HEALTH_CHECK_INTERVAL=60000

# Rate Limit
RATE_LIMIT_COOLDOWN=60000
RATE_LIMIT_MAX_CONSECUTIVE=5

# Retry
MAX_RETRIES=3
RETRY_DELAY_BASE=1000
RETRY_DELAY_MAX=30000

# Claude API
CLAUDE_BASE_URL=https://api.anthropic.com
CLAUDE_API_TIMEOUT=300000

# Logging
LOG_LEVEL=info

# Dashboard
DASHBOARD_ENABLED=true
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=
